<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Registro de Encargos</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    min-height:100vh;

    display:flex;
    justify-content:center;
    align-items:center;

    background:
    radial-gradient(circle at center,
    #2a143f 0%,
    #12091f 40%,
    #050308 100%);

    font-family:'Cinzel', serif;
}

.libro{

    width:1200px;
    height:800px;

    background:
    linear-gradient(
    90deg,
    #16101f 0%,
    #1f152b 45%,
    #120c19 50%,
    #1f152b 55%,
    #16101f 100%);

    border:2px solid #7f59d8;

    box-shadow:
    0 0 100px rgba(127,89,216,.25);

    display:flex;

    position:relative;
}

.libro::after{

    content:"";

    position:absolute;

    left:50%;
    top:0;

    width:2px;
    height:100%;

    background:#7f59d8;

    transform:translateX(-50%);
}

.pagina{

    flex:1;

    padding:50px;

    display:flex;
    flex-direction:column;

    align-items:center;
    justify-content:center;

    text-align:center;
}

.foto{

    width:280px;
    height:380px;

    border:2px solid #7f59d8;

    overflow:hidden;

    margin-bottom:30px;
}

.foto img{

    width:100%;
    height:100%;

    object-fit:cover;
}

.nombre{

    color:#f3e9ff;

    font-size:2rem;

    margin-bottom:10px;
}

.casa{

    color:#b88cff;

    margin-bottom:30px;
}

.boton{

    text-decoration:none;

    color:white;

    border:1px solid #8f69ff;

    padding:15px 35px;

    transition:.3s;
}

.boton:hover{

    background:rgba(143,105,255,.15);
}

.titulo{

    position:absolute;

    top:30px;
    left:50%;

    transform:translateX(-50%);

    color:#b88cff;

    letter-spacing:8px;

    font-size:1rem;
}

.volver{

    position:absolute;

    bottom:25px;
    left:50%;

    transform:translateX(-50%);

    color:#b88cff;

    text-decoration:none;
}

</style>
</head>

<body>

<div class="libro">

<div class="titulo">
REGISTRO DE ENCARGOS
</div>

<div class="pagina">

<div class="foto">
<img src="amelia.jpg">
</div>

<div class="nombre">
Amelia Crawford
</div>

<div class="casa">
Ravenclaw
</div>

<a href="amelia.html" class="boton">
Ver Expediente
</a>

</div>

<div class="pagina">

<div class="foto">
<img src="vivi.jpg">
</div>

<div class="nombre">
Vivi Ornitier
</div>

<div class="casa">
Ravenclaw
</div>

<a href="vivi.html" class="boton">
Ver Expediente
</a>

</div>

<a href="index.html" class="volver">
✦ Cerrar Grimorio ✦
</a>

</div>

</body>
</html>
